CONFIG_CRYPTO_CHACHA20POLY1305=y      # ChaCha20-Poly1305 AEAD
CONFIG_CRYPTO_HMAC=y                  # HMAC
CONFIG_CRYPTO_HKDF=y                  # HKDF (for WireGuard)
CONFIG_CRYPTO_MD5=y                   # MD5 (still needed for some protocols)
CONFIG_CRYPTO_POLY1305=y              # Poly1305 (for WireGuard)
CONFIG_CRYPTO_RNG=y                   # RNG
CONFIG_CRYPTO_DRBG_MENU=y
CONFIG_CRYPTO_JITTERENTROPY=y
CONFIG_CRYPTO_SHA1=y                  # SHA-1
CONFIG_CRYPTO_SHA256=y                # SHA-256
CONFIG_CRYPTO_SHA512=y                # SHA-512
CONFIG_CRYPTO_SHA3=y                  # SHA-3
CONFIG_CRYPTO_SM3=n
CONFIG_CRYPTO_XTS=y                   # XTS mode (for disk encryption)
CONFIG_CRYPTO_XXHASH=y                # xxHash (for data dedup)
CONFIG_CRYPTO_BLAKE2B=y
CONFIG_CRYPTO_BLAKE2S=y
CONFIG_CRYPTO_LIB_BLAKE2S=y
CONFIG_CRYPTO_LIB_CHACHA20=y
CONFIG_CRYPTO_LIB_CURVE25519=y
CONFIG_CRYPTO_LIB_POLY1305=y
CONFIG_CRYPTO_LIB_SHA256=y

# Hardware crypto acceleration
CONFIG_CRYPTO_AES_NI_INTEL=y          # AES-NI (Intel)
CONFIG_CRYPTO_SHA256_SSSE3=y          # SSSE3-accelerated SHA-256
CONFIG_CRYPTO_SHA512_SSSE3=y          # SSSE3-accelerated SHA-512
CONFIG_CRYPTO_CRC32C_INTEL=y          # CRC32C hardware
CONFIG_CRYPTO_CRCT10DIF_INTEL=n
CONFIG_CRYPTO_GHASH_CLMUL_NI_INTEL=y  # PCLMULQDQ GHASH

#
# Library routines
#
CONFIG_CRC_CCITT=y
CONFIG_CRC16=y
CONFIG_CRC_T10DIF=y
CONFIG_CRC_ITU_T=y
CONFIG_CRC32=y
CONFIG_CRC32_SELFTEST=n
CONFIG_CRC32_SLICEBY8=y
CONFIG_CRC64=y
CONFIG_LZO_COMPRESS=y
CONFIG_LZO_DECOMPRESS=y
CONFIG_LZ4_COMPRESS=y
CONFIG_LZ4_DECOMPRESS=y
CONFIG_ZSTD_COMPRESS=y
CONFIG_ZSTD_DECOMPRESS=y
CONFIG_XZ_DEC=y                       # XZ decompression (for kernel/modules)
CONFIG_XZ_DEC_X86=y
CONFIG_XZ_DEC_POWERPC=n
CONFIG_XZ_DEC_IA64=n
CONFIG_XZ_DEC_ARM=n
CONFIG_XZ_DEC_ARMTHUMB=n
CONFIG_XZ_DEC_SPARC=n
CONFIG_XZ_DEC_MICROLZMA=n
CONFIG_DECOMPRESS_GZIP=y
CONFIG_DECOMPRESS_BZIP2=y
CONFIG_DECOMPRESS_LZMA=y
CONFIG_DECOMPRESS_XZ=y
CONFIG_DECOMPRESS_LZO=y
CONFIG_DECOMPRESS_LZ4=y
CONFIG_DECOMPRESS_ZSTD=y
CONFIG_GENERIC_ALLOCATOR=y
CONFIG_GENERIC_IOMAP=y
CONFIG_STAGING=n                       # No staging drivers
CONFIG_GLOB=y
CONFIG_CLZ_TAB=y
CONFIG_IRQ_POLL=y
CONFIG_DIMLIB=y
CONFIG_OID_REGISTRY=y
CONFIG_UCS2_STRING=y
CONFIG_HAVE_GENERIC_VDSO=y
CONFIG_GENERIC_GETTIMEOFDAY=y
CONFIG_GENERIC_VDSO_IMAGE=y
CONFIG_GENERIC_VDSO32_LAYOUT=y
CONFIG_VDSO32=y
CONFIG_MODULES=n                       # NO MODULE SUPPORT — all drivers built-in
# CONFIG_MODULE_DEBUG is not set
# CONFIG_MODULE_SIG is not set
# CONFIG_MODULE_COMPRESS is not set
# CONFIG_MODULE_ALLOW_MISSING_NAMESPACE_IMPORTS is not set
# CONFIG_UNUSED_SYMBOLS is not set

#
# Kernel hacking — minimized for production
#
# CONFIG_DEBUG_KERNEL is not set       # No debug
CONFIG_DEBUG_MISC=n
# CONFIG_FRAME_POINTER is not set     # No frame pointers (performance)
CONFIG_STACK_VALIDATION=y
CONFIG_SECTION_MISMATCH_WARN_ONLY=y
# CONFIG_DEBUG_FS is not set          # No debugfs
# CONFIG_DEBUG_STACKOVERFLOW is not set
# CONFIG_DEBUG_STACK_USAGE is not set
# CONFIG_DEBUG_PER_CPU_MAPS is not set
# CONFIG_DEBUG_TIMEKEEPING is not set
# CONFIG_DEBUG_VM is not set
# CONFIG_DEBUG_VIRTUAL is not set
# CONFIG_DEBUG_LIST is not set
# CONFIG_DEBUG_PLIST is not set
# CONFIG_DEBUG_SG is not set
# CONFIG_DEBUG_NOTIFIERS is not set
# CONFIG_DEBUG_CREDENTIALS is not set

#
# Printk
#
CONFIG_PRINTK=y
CONFIG_PRINTK_SAFE_LOG_BUF_SHIFT=13
CONFIG_CONSOLE_LOGLEVEL_DEFAULT=7
CONFIG_CONSOLE_LOGLEVEL_QUIET=4
CONFIG_MESSAGE_LOGLEVEL_DEFAULT=4
CONFIG_BOOT_PRINTK_DELAY=n
CONFIG_DYNAMIC_DEBUG=n
CONFIG_SYMBOLIC_ERRNAME=y

#
# Compile-time checks
#
CONFIG_DEBUG_INFO=n                    # No debug info (reduces size)
# CONFIG_DEBUG_INFO_DWARF4 is not set
# CONFIG_DEBUG_INFO_DWARF5 is not set
# CONFIG_GDB_SCRIPTS is not set
CONFIG_FRAME_WARN=2048
CONFIG_STRIP_ASM_SYMS=y
CONFIG_READABLE_ASM=n
CONFIG_HEADERS_INSTALL=n
CONFIG_DEBUG_SECTION_MISMATCH=y
CONFIG_SECTION_MISMATCH_WARN_ONLY=y
CONFIG_MAGIC_SYSRQ=y                   # SysRq (for emergency operations)
CONFIG_MAGIC_SYSRQ_DEFAULT_ENABLE=0x01b6
CONFIG_MAGIC_SYSRQ_SERIAL=n
CONFIG_DEBUG_MEMORY_INIT=n
# CONFIG_SCHED_STACK_END_CHECK is not set
CONFIG_BUG=y
CONFIG_BUG_ON_DATA_CORRUPTION=y

#
# Virtualization
#
CONFIG_KVM=y
CONFIG_KVM_INTEL=y                     # KVM Intel (VMX)
CONFIG_KVM_AMD=y                       # KVM AMD (SVM)
CONFIG_KVM_MMU_AUDIT=n
CONFIG_AS_AVX512=y
CONFIG_AS_SHA1_NI=y
CONFIG_AS_SHA256_NI=y
CONFIG_AS_TPAUSE=y
CONFIG_AS_GFNI=y
CONFIG_AS_WRUSS=y

#
# Last check: ensure no modules
#
# CONFIG_MODULES is not set            # CONFIG_MODULES must NOT be set

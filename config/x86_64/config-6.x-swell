#
# Swell kernel — monolithic x86_64 configuration
#
# Design: monolithic (no modules), performance-patched,
# all common drivers baked in, no legacy hardware.
# Target size: ~4-6 MB uncompressed.
#
# Based on Linux 6.x. Every option is documented.
#

#
# General setup
#
CONFIG_INIT_ENV_ARG_LIMIT=32
CONFIG_LOCALVERSION="-swell"
# CONFIG_LOCALVERSION_AUTO is not set
CONFIG_BUILD_SALT="swell"
CONFIG_DEFAULT_HOSTNAME="swell"
CONFIG_SWAP=y
# CONFIG_SYSVIPC is not set              # No System V IPC — modern systems use memfd/signalfd
# CONFIG_POSIX_MQUEUE is not set         # No POSIX message queues
CONFIG_WATCH_QUEUE=y                     # Watch queue for pipe/event notifications
CONFIG_CROSS_MEMORY_ATTACH=y             # Cross memory attach for process_vm_readv/writev
# CONFIG_USELIB is not set               # No uselib syscall (obsolete)
CONFIG_AUDIT=y                           # Auditing support
CONFIG_HAVE_ARCH_AUDITSYSCALL=y

#
# IRQ subsystem
#
CONFIG_GENERIC_IRQ_PROBE=y
CONFIG_GENERIC_IRQ_SHOW=y
CONFIG_GENERIC_IRQ_EFFECTIVE_AFF_MASK=y
CONFIG_GENERIC_PENDING_IRQ=y
CONFIG_IRQ_DOMAIN=y
CONFIG_IRQ_DOMAIN_HIERARCHY=y
CONFIG_IRQ_FASTEOI_HIERARCHY_HANDLERS=y
CONFIG_GENERIC_MSI_IRQ=y
CONFIG_GENERIC_MSI_IRQ_DOMAIN=y
CONFIG_IRQ_MSI_IOMMU=y
CONFIG_IRQ_FORCED_THREADING=y
CONFIG_SPARSE_IRQ=y                     # Sparse IRQs for better memory usage

#
# Timers subsystem
#
CONFIG_HZ_PERIODIC=y                    # Periodic timer by default
CONFIG_NO_HZ_IDLE=y                     # Tickless idle (dynticks)
CONFIG_NO_HZ=y                          # Enable tickless
CONFIG_HIGH_RES_TIMERS=y                # High-resolution timers
CONFIG_CLOCKSOURCE_WATCHDOG=y

#
# CPU/Task time and stats accounting
#
CONFIG_TICK_ONESHOT=y
CONFIG_NO_HZ_COMMON=y
CONFIG_TICK_CPU_ACCOUNTING=y            # Simple tick-based CPU accounting
# CONFIG_VIRT_CPU_ACCOUNTING_NATIVE is not set
# CONFIG_IRQ_TIME_ACCOUNTING is not set
# CONFIG_BSD_PROCESS_ACCT is not set
# CONFIG_TASKSTATS is not set           # No taskstats (reduces overhead)
CONFIG_CPU_ISOLATION_OPT=y              # CPU isolation support
CONFIG_PADATA=y                         # Parallel data processing

#
# RCU subsystem
#
CONFIG_RCU_EXPERT=y
CONFIG_SRCU=y
CONFIG_TREE_SRCU=y
CONFIG_TASKS_RCU_GENERIC=y
CONFIG_FORCE_TASKS_RCU=y
CONFIG_TASKS_RUDE_RCU=y
CONFIG_TASKS_TRACE_RCU=y
CONFIG_RCU_STALL_COMMON=y
CONFIG_RCU_NEED_SEGCBLIST=y
CONFIG_RCU_NOCB_CPU=y                   # Offload RCU callbacks for real-time/performance
# CONFIG_RCU_EXPEDITE_BOOT is not set   # Don't expedite RCU at boot

#
# Scheduler
#
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y                 # CFS bandwidth control
CONFIG_RT_GROUP_SCHED=y
CONFIG_SCHED_MM_CID=y
CONFIG_SCHED_SMT=y                     # SMT (Hyper-Threading) awareness

# Preemption model: Fully Preemptible (low-latency desktop)
CONFIG_PREEMPT_BUILD=y
CONFIG_PREEMPT=y                       # Preemptible kernel (low-latency)
# CONFIG_PREEMPT_NONE is not set       # No voluntary preemption
# CONFIG_PREEMPT_VOLUNTARY is not set  # No full preemption (voluntary)
# CONFIG_PREEMPT_RT is not set         # Not using RT patch (for now)
CONFIG_PREEMPT_COUNT=y
CONFIG_PREEMPTION=y
CONFIG_PREEMPT_DYNAMIC=y

#
# CPU isolation
#
# CONFIG_HZ_100 is not set
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
CONFIG_HZ_1000=y                       # 1000 Hz for desktop responsiveness
CONFIG_HZ=1000
CONFIG_SCHED_HRTICK=y
# CONFIG_SCHED_CORE is not set

#
# Kernel config and compression
#
CONFIG_KERNEL_GZIP=y                   # Gzip compressed kernel (smaller than bzImage)
# CONFIG_KERNEL_BZIP2 is not set
# CONFIG_KERNEL_LZMA is not set
# CONFIG_KERNEL_XZ is not set
# CONFIG_KERNEL_LZO is not set
# CONFIG_KERNEL_LZ4 is not set
# CONFIG_KERNEL_ZSTD is not set
CONFIG_KERNEL_UNCOMPRESSED=n           # Compressed kernel

#
# Kernel Performance Events
#
CONFIG_PERF_EVENTS=y                   # Perf events support
CONFIG_PERF_EVENTS_INTEL_UNCORE=y
CONFIG_PERF_EVENTS_INTEL_RAPL=y
CONFIG_PERF_EVENTS_INTEL_CSTATE=y
CONFIG_PERF_EVENTS_AMD_POWER=y
CONFIG_PERF_EVENTS_AMD_UNCORE=y
CONFIG_PERF_EVENTS_AMD_BRS=y

#
# BPF subsystem
#
CONFIG_BPF=y
CONFIG_BPF_LSM=y                       # BPF LSM (security)
CONFIG_BPF_SYSCALL=y                   # BPF syscall
CONFIG_BPF_JIT=y                       # BPF JIT compiler
CONFIG_BPF_JIT_ALWAYS_ON=y             # Always enable JIT (security)
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y        # Unprivileged BPF disabled by default
CONFIG_BPF_PRELOAD=y
CONFIG_BPF_PRELOAD_UMD=y
CONFIG_IPV6_SEG6_BPF=y
CONFIG_NET_SCH_FQ=y                    # Fair Queue (used with BPF)

#
# Speculation mitigations
#
CONFIG_MITIGATION_PAGE_TABLE_ISOLATION=y     # PTI for Meltdown
CONFIG_MITIGATION_RETPOLINE=y                # Retpoline for Spectre v2
CONFIG_MITIGATION_RETHUNK=y
CONFIG_MITIGATION_UNRET_ENTRY=y
CONFIG_MITIGATION_CALL_DEPTH_TRACKING=y
CONFIG_MITIGATION_SMT=y                     # SMT mitigation handling
CONFIG_MITIGATION_IBPB=y                    # IBPB for Spectre v2
CONFIG_MITIGATION_IBRS=y                    # IBRS for Spectre v2
CONFIG_MITIGATION_SRSO=y                    # SRSO mitigation
CONFIG_MITIGATION_SRSO_CMD=ibpb
CONFIG_MITIGATION_GDS=y
CONFIG_MITIGATION_RFDS=y
CONFIG_MITIGATION_MMIO_STALE_DATA=y
CONFIG_MITIGATION_RETBLEED=y
CONFIG_MITIGATION_SPECTRE_BHI=y
CONFIG_ARCH_HAS_ADD_PAGES=y
CONFIG_ARCH_MHP_MEMMAP_ON_MEMORY_ENABLE=y

#
# General architecture-dependent options
#
CONFIG_HOTPLUG_CORE_SYNC=y
CONFIG_HOTPLUG_CORE_SYNC_DEAD=y
CONFIG_HOTPLUG_CORE_SYNC_FULL=y
CONFIG_ARCH_PROC_KCORE_TEXT=y
CONFIG_KALLSYMS=y                      # Kernel symbol table (for debugging/profiling)
CONFIG_KALLSYMS_ALL=y
CONFIG_KALLSYMS_BASE_RELATIVE=y
CONFIG_ARCH_HAS_MEMBARRIER_SYNC_CORE=y
CONFIG_KCMP=y                          # kcmp syscall (used by checkpoint/restore tools)
CONFIG_RSEQ=y                          # Restartable sequences
CONFIG_EMBEDDED=n                      # Not ultra-embedded; full desktop kernel
CONFIG_HAVE_PERF_EVENTS=y
CONFIG_PC104=n                         # No PC/104 bus support

#
# Kernel options
#
# CONFIG_HZ_100 is not set
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_SCHED_HRTICK=y
CONFIG_KEXEC=y                         # Kexec for fast reboots
CONFIG_KEXEC_FILE=y
CONFIG_ARCH_HAS_KEXEC_PURGATORY=y
CONFIG_KEXEC_SIG=n                     # No kexec signature verification
CONFIG_CRASH_DUMP=n                    # No crash dump (we don't need kdump)
CONFIG_PHYSICAL_START=0x1000000
CONFIG_RELOCATABLE=y
CONFIG_RANDOMIZE_BASE=y                # KASLR for security
CONFIG_X86_NEED_RELOCS=y
CONFIG_PHYSICAL_ALIGN=0x200000
CONFIG_DYNAMIC_MEMORY_LAYOUT=y
CONFIG_RANDOMIZE_MEMORY=y              # Randomize kernel memory layout
CONFIG_RANDOMIZE_MEMORY_PHYSICAL_PADDING=0x0
CONFIG_HOTPLUG_CPU=y                   # CPU hotplug
CONFIG_BOOTPARAM_HOTPLUG_CPU0=n
CONFIG_COMPAT_VDSO=y

#
# Power management
#
CONFIG_SUSPEND=y                       # Suspend to RAM
# CONFIG_SUSPEND_SKIP_SYNC is not set
CONFIG_HIBERNATION=n                   # No hibernation (swap-based, not needed)
CONFIG_PM_SLEEP=y
CONFIG_PM_AUTOSLEEP=n                  # No automatic sleep
CONFIG_PM_WAKELOCKS=n
CONFIG_PM_ADVANCED_DEBUG=n
CONFIG_PM_CLK=y
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=n
CONFIG_PM_GENERIC_DOMAINS_SLEEP=y
CONFIG_ENERGY_MODEL=n                  # No energy model (performance focus)
# CONFIG_CPU_FREQ is not set           # No CPU freq scaling (runs at max perf)
# CONFIG_CPU_IDLE is not set           # No CPU idle governors (performance)

#
# CPU idle
#
# CONFIG_CPU_IDLE is not set           # Performance-first; no idle tuning

#
# Memory management
#
CONFIG_SELECT_MEMORY_MODEL=y
CONFIG_SPARSEMEM_MANUAL=y
CONFIG_SPARSEMEM=y
CONFIG_NEED_MULTIPLE_NODES=y
CONFIG_SPARSEMEM_EXTREME=y
CONFIG_SPARSEMEM_VMEMMAP_ENABLE=y
CONFIG_SPARSEMEM_VMEMMAP=y
CONFIG_HAVE_FAST_GUP=y
CONFIG_MEMORY_COMPACTION=y
CONFIG_COMPACTION=y                    # Memory compaction for defragmentation
CONFIG_PAGE_REPORTING=y
CONFIG_MIGRATION=y
CONFIG_CONTIG_ALLOC=y
CONFIG_PHYS_ADDR_T_64BIT=y
CONFIG_BOUNCE=y
CONFIG_VIRT_TO_BUS=n                   # No virt_to_bus (legacy)
CONFIG_MMU=y
CONFIG_ARCH_MMAP_RND_BITS=32
CONFIG_HAVE_ARCH_MMAP_RND_COMPAT_BITS=y
CONFIG_ARCH_MMAP_RND_COMPAT_BITS=8
CONFIG_PAGE_POISONING=n                # No page poisoning (performance)
CONFIG_DEBUG_PAGEALLOC=n
CONFIG_ARCH_HAS_PKEYS=y
CONFIG_ARCH_ENABLE_HUGEPAGE_MIGRATION=y
CONFIG_ARCH_ENABLE_THP_MIGRATION=y
CONFIG_TRANSPARENT_HUGEPAGE=y          # THP for performance
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y   # Always use THP (madvise is more conservative)
# CONFIG_TRANSPARENT_HUGEPAGE_MADVISE is not set
CONFIG_READ_ONLY_THP_FOR_FS=y
CONFIG_NEED_PER_CPU_EMBED_FIRST_CHUNK=y
CONFIG_NEED_PER_CPU_PAGE_FIRST_CHUNK=y
CONFIG_USE_PERCPU_NUMA_NODE_ID=y
CONFIG_HAVE_SETUP_PER_CPU_AREA=y
CONFIG_CMA=y                           # Contiguous Memory Allocator (for GPU/DMA)
CONFIG_CMA_AREAS=7
CONFIG_MEM_SOFT_DIRTY=y
CONFIG_ZSWAP=y                         # Compressed swap cache
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_DEFLATE=n
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_LZO=n
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_LZ4=n
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_LZ4HC=n
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZBUD=n
CONFIG_ZSWAP_ZPOOL_DEFAULT_Z3FOLD=n
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_ZSMALLOC=y                      # zsmalloc allocator (for zswap/zram)
CONFIG_ZSMALLOC_STAT=n
CONFIG_ZRAM=y                          # Compressed RAM block device
CONFIG_ZRAM_BACKEND=zstd
CONFIG_ZRAM_DEF_COMP=lz4
CONFIG_ZRAM_MULTI_COMP=y
CONFIG_ZRAM_WRITEBACK=n
CONFIG_ZRAM_MEMORY_TRACKING=n
CONFIG_NET_API=y
CONFIG_PAGE_POOL=y
CONFIG_PAGE_IDLE_FLAG=y
CONFIG_IDLE_PAGE_TRACKING=y
CONFIG_FRAGMENT_LIST=y
CONFIG_FOLIO_ZERO=y
CONFIG_ZONE_DMA=y
CONFIG_ZONE_DMA32=y
CONFIG_ZONE_DEVICE=n
CONFIG_HMM_MIRROR=n
CONFIG_GET_FREE_REGION=y
CONFIG_VM_EVENT_COUNTERS=y
CONFIG_PERCPU_STATS=y
CONFIG_GUP_TEST=n
CONFIG_ANON_VMA_NAME=y
CONFIG_USERFAULTFD=n
CONFIG_LRU_GEN=y                       # Multi-generational LRU
CONFIG_LRU_GEN_ENABLED=y               # Enabled by default
CONFIG_LRU_GEN_STATS=n
CONFIG_MM_IDLE=y
CONFIG_ARCH_SUPPORTS_PER_VMA_LOCK=y
CONFIG_PER_VMA_LOCK=y
CONFIG_LOCK_MM_AND_FIND_VMA=y

#
# Netfilter
#
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_INGRESS=y
CONFIG_NETFILTER_EGRESS=y
CONFIG_NETFILTER_SKIP_EGRESS=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NETFILTER_NETLINK_ACCT=y
CONFIG_NETFILTER_NETLINK_QUEUE=y
CONFIG_NETFILTER_NETLINK_LOG=y
CONFIG_NETFILTER_NETLINK_OSF=y
CONFIG_NF_CONNTRACK=y                  # Connection tracking
CONFIG_NF_LOG_SYSLOG=y
CONFIG_NF_NAT=y                        # NAT support
CONFIG_NF_NAT_REDIRECT=y
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_NETFILTER_SYNPROXY=y
CONFIG_NF_TABLES=y                     # nftables (modern firewall)
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NFT_NUMGEN=y
CONFIG_NFT_CT=y
CONFIG_NFT_FLOW_OFFLOAD=y
CONFIG_NFT_CONNLIMIT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_NAT=y
CONFIG_NFT_TUNNEL=y
CONFIG_NFT_OBJREF=y
CONFIG_NFT_QUEUE=y
CONFIG_NFT_QUOTA=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_REJECT_INET=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_HASH=y
CONFIG_NFT_FIB=y
CONFIG_NFT_FIB_INET=y
CONFIG_NFT_XFRM=y
CONFIG_NFT_SOCKET=y
CONFIG_NFT_OSF=y
CONFIG_NFT_TPROXY=y
CONFIG_NFT_SYNPROXY=y
CONFIG_NFT_DUP_NETDEV=y
CONFIG_NFT_FWD_NETDEV=y
CONFIG_NFT_FIB_NETDEV=y
CONFIG_NFT_REJECT_NETDEV=y
CONFIG_NF_FLOW_TABLE=y
CONFIG_NF_FLOW_TABLE_INET=y
CONFIG_NF_FLOW_TABLE_NETDEV=y
CONFIG_NETFILTER_XTABLES=y            # iptables compatibility
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_CONNMARK=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_IP_SET=y                        # IP set for blacklists
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_IP_SET_HASH_NETPORT=y
CONFIG_IP_VS=y                         # IP Virtual Server
CONFIG_IP_VS_NFCT=y
CONFIG_IP_VS_SH_TAB_BITS=16

#
# Core networking
#
CONFIG_NET=y
CONFIG_NET_INGRESS=y
CONFIG_NET_EGRESS=y
CONFIG_NET_REDIRECT=y
CONFIG_NET_XGRESS=y
CONFIG_SKB_EXTENSIONS=y
CONFIG_PACKET=y                        # Packet socket (for dhcpcd, tcpdump)
CONFIG_PACKET_DIAG=y
CONFIG_UNIX=y                          # Unix domain sockets
CONFIG_UNIX_DIAG=y
CONFIG_TLS=y                           # TLS offload
CONFIG_TLS_DEVICE=y
CONFIG_XFRM=y                          # IPsec
CONFIG_XFRM_USER=y
CONFIG_XFRM_INTERFACE=y
CONFIG_XFRM_SUB_POLICY=y
CONFIG_XFRM_MIGRATE=y
CONFIG_XFRM_STATISTICS=y
CONFIG_NET_KEY=y                       # PF_KEY socket (for IPsec)
CONFIG_INET=y                          # IPv4
CONFIG_IP_MULTICAST=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_FIB_TRIE_STATS=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IP_ROUTE_VERBOSE=y
CONFIG_IP_PNP=y                        # IP autoconfiguration (for NFS root)
CONFIG_IP_PNP_DHCP=y
CONFIG_NET_IPIP=y                      # IP-in-IP tunneling
CONFIG_NET_IPGRE_DEMUX=y
CONFIG_NET_IPGRE=y
CONFIG_NET_IPGRE_BROADCAST=y
CONFIG_IP_MROUTE=y
CONFIG_IP_MROUTE_MULTIPLE_TABLES=y
CONFIG_IP_PIMSM_V1=y
CONFIG_IP_PIMSM_V2=y
CONFIG_SYN_COOKIES=y                   # SYN cookies (DoS protection)
CONFIG_NET_IPVTI=y
CONFIG_NET_UDP_TUNNEL=y
CONFIG_NET_FOU=y
CONFIG_NET_FOU_IP_TUNNELS=y
CONFIG_INET_AH=y
CONFIG_INET_ESP=y
CONFIG_INET_IPCOMP=y
CONFIG_INET_TABLE_PERTURB=y
CONFIG_INET_DIAG=y
CONFIG_INET_TCP_DIAG=y
CONFIG_INET_UDP_DIAG=y
CONFIG_INET_RAW_DIAG=y
CONFIG_INET_DIAG_DESTROY=y
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BIC=y
CONFIG_TCP_CONG_CUBIC=y                # CUBIC (default congestion control)
CONFIG_TCP_CONG_WESTWOOD=y
CONFIG_TCP_CONG_HTCP=y
CONFIG_TCP_CONG_HSTCP=y
CONFIG_TCP_CONG_HYBLA=y
CONFIG_TCP_CONG_VEGAS=y
CONFIG_TCP_CONG_NV=y
CONFIG_TCP_CONG_SCALABLE=y
CONFIG_TCP_CONG_LP=y
CONFIG_TCP_CONG_VENO=y
CONFIG_TCP_CONG_YEAH=y
CONFIG_TCP_CONG_ILLINOIS=y
CONFIG_TCP_CONG_DCTCP=y
CONFIG_TCP_CONG_CDG=y
CONFIG_TCP_CONG_BBR=y                  # BBR congestion control
CONFIG_TCP_CONG_BBR2=y
CONFIG_DEFAULT_CUBIC=y
CONFIG_DEFAULT_TCP_CONG="cubic"
CONFIG_TCP_MD5SIG=y
CONFIG_IPV6=y                          # IPv6
CONFIG_IPV6_ROUTER_PREF=y
CONFIG_IPV6_ROUTE_INFO=y
CONFIG_IPV6_OPTIMISTIC_DAD=y
CONFIG_INET6_AH=y
CONFIG_INET6_ESP=y
CONFIG_INET6_IPCOMP=y
CONFIG_IPV6_MIP6=y
CONFIG_IPV6_ILA=y
CONFIG_IPV6_VTI=y
CONFIG_IPV6_SIT=y
CONFIG_IPV6_SIT_6RD=y
CONFIG_IPV6_NDISC_NODETYPE=y
CONFIG_IPV6_TUNNEL=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_SUBTREES=y
CONFIG_IPV6_MROUTE=y
CONFIG_IPV6_MROUTE_MULTIPLE_TABLES=y
CONFIG_IPV6_PIMSM_V2=y
CONFIG_IPV6_SEG6_LWTUNNEL=y
CONFIG_IPV6_SEG6_HMAC=y
CONFIG_NETLABEL=y
CONFIG_MPTCP=y                         # Multipath TCP
CONFIG_MPTCP_IPV6=y
CONFIG_NETWORK_SECMARK=y
CONFIG_NET_PTP_CLASSIFY=y
CONFIG_NETWORK_PHY_TIMESTAMPING=y
CONFIG_NETFILTER_NETLINK_GLUE_CT=y
CONFIG_NET_DEVLINK=y
CONFIG_PAGE_POOL_STATS=n
CONFIG_FAILOVER=y

#
# Network packet scheduler
#
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_FIFO=y
CONFIG_NET_SCH_FQ=y                    # Fair Queue
CONFIG_NET_SCH_FQ_CODEL=y              # fq_codel (default qdisc)
CONFIG_NET_SCH_CAKE=y                  # CAKE qdisc (bufferbloat)
CONFIG_NET_SCH_CODEL=y
CONFIG_NET_SCH_INGRESS=y
CONFIG_NET_SCH_PLUG=y
CONFIG_NET_CLS=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_CLS_FW=y
CONFIG_NET_CLS_FLOW=y
CONFIG_NET_CLS_CGROUP=y
CONFIG_NET_EMATCH=y
CONFIG_NET_EMATCH_CMP=y
CONFIG_NET_EMATCH_NBYTE=y
CONFIG_NET_EMATCH_U32=y
CONFIG_NET_EMATCH_META=y
CONFIG_NET_EMATCH_TEXT=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_ACT_POLICE=y
CONFIG_NET_ACT_GACT=y
CONFIG_NET_ACT_MIRRED=y
CONFIG_NET_ACT_SKBEDIT=y
CONFIG_NET_ACT_CSUM=y
CONFIG_NET_ACT_MPLS=y
CONFIG_NET_ACT_VLAN=y
CONFIG_NET_ACT_BPF=y
CONFIG_NET_ACT_CONNMARK=y
CONFIG_NET_ACT_CTINFO=y
CONFIG_NET_ACT_SIMP=y
CONFIG_NET_HAVE_GRO=y
CONFIG_NET_GRO=y                       # Generic Receive Offload
CONFIG_GRO_CELLS=y
CONFIG_NET_SWITCHDEV=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_NET_VENDOR_SAMSUNG=y
CONFIG_NET_VENDOR_SEEQ=n

#
# DNS resolver
#
CONFIG_DNS_RESOLVER=y                  # DNS resolution in kernel

#
# BPF based networking
#
CONFIG_BPF_STREAM_PARSER=y
CONFIG_AF_KCM=y

#
# Wireless networking
#
CONFIG_CFG80211=y                      # cfg80211 (wireless configuration)
CONFIG_NL80211_TESTMODE=y
CONFIG_CFG80211_DEVELOPER_WARNINGS=n
CONFIG_CFG80211_CERTIFICATION_ONUS=y
CONFIG_CFG80211_REQUIRE_SIGNED_REGDB=y
CONFIG_CFG80211_USE_KERNEL_REGDB_KEYS=y
CONFIG_CFG80211_DEFAULT_PS=y
CONFIG_CFG80211_CRDA_SUPPORT=y
CONFIG_CFG80211_WEXT=y                 # Wireless extensions (for iwconfig compat)
CONFIG_MAC80211=y                      # mac80211 (soft-MAC wireless)
CONFIG_MAC80211_HAS_RC=y
CONFIG_MAC80211_RC_MINSTREL=y
CONFIG_MAC80211_RC_DEFAULT_MINSTREL=y
CONFIG_MAC80211_RC_DEFAULT="minstrel_ht"
CONFIG_MAC80211_MESH=y
CONFIG_WANT_DEV_COREDUMP=y
CONFIG_DEV_COREDUMP=y

#
# RF switch subsystem
#
CONFIG_RFKILL=y                        # RF kill switch support
CONFIG_RFKILL_INPUT=y
CONFIG_RFKILL_GPIO=y

#
# Ethernet driver support
#
CONFIG_NET_VENDOR_INTEL=y
CONFIG_IGB=y                           # Intel Gigabit Ethernet
CONFIG_IGC=y                           # Intel 2.5G Ethernet (I225/I226)
CONFIG_IXGBE=y                         # Intel 10G Ethernet
CONFIG_IXGBEVF=y
CONFIG_I40E=y                          # Intel 40G Ethernet
CONFIG_ICE=y                           # Intel E800 series
CONFIG_E1000=y                         # Intel PRO/1000
CONFIG_E1000E=y                        # Intel PRO/1000 PCIe

CONFIG_NET_VENDOR_AMD=y
CONFIG_AMD_XGBE=y                      # AMD 10G Ethernet

CONFIG_NET_VENDOR_BROADCOM=y
CONFIG_BNX2X=y                        # Broadcom NetXtreme II
CONFIG_TIGON3=y                       # Broadcom Tigon3

CONFIG_NET_VENDOR_MARVELL=y
CONFIG_MVMDIO=y
CONFIG_SKGE=y                         # Marvell Yukon
CONFIG_SKY2=y

CONFIG_NET_VENDOR_MELLANOX=y
CONFIG_MLX5_CORE=y                    # Mellanox ConnectX (datacenter)
CONFIG_MLX4_EN=y                      # Mellanox ConnectX-3

CONFIG_NET_VENDOR_REALTEK=y
CONFIG_R8169=y                        # Realtek 8169 (most common onboard NIC)

CONFIG_NET_VENDOR_SAMSUNG=y
CONFIG_NET_VENDOR_SEEQ=n

CONFIG_NET_VENDOR_SILAN=n
CONFIG_NET_VENDOR_SIS=n

CONFIG_NET_VENDOR_SOLARFLARE=n
CONFIG_NET_VENDOR_SFC=n

CONFIG_NET_VENDOR_SMSC=y
CONFIG_SMC91X=y
CONFIG_SMSC911X=y

CONFIG_NET_VENDOR_STMICRO=n
CONFIG_NET_VENDOR_SUN=n

CONFIG_NET_VENDOR_TEHUTI=n
CONFIG_NET_VENDOR_TI=y
CONFIG_TI_CPSW_PHY_SEL=y

CONFIG_NET_VENDOR_VIA=n
CONFIG_NET_VENDOR_WIZNET=n

CONFIG_NET_VENDOR_AQUANTIA=y
CONFIG_AQTION=y                       # Aquantia AQC107 10G

CONFIG_NET_VENDOR_NETRONOME=n
CONFIG_NET_VENDOR_FUNGIBLE=n

CONFIG_NET_VENDOR_ADIN=y
CONFIG_NET_VENDOR_ASIX=y

#
# Wireless LAN
#
CONFIG_WLAN=y
# CONFIG_WLAN_VENDOR_ADMTEK is not set
# CONFIG_WLAN_VENDOR_ATH is not set    # No Atheros (legacy)
CONFIG_WLAN_VENDOR_INTEL=y
CONFIG_IWLWIFI=y                      # Intel Wireless WiFi
CONFIG_IWLWIFI_LEDS=y
CONFIG_IWLDVM=y                       # Intel 6000/1000/5000 series
CONFIG_IWLMVM=y                       # Intel 7000/8000/9000 series
CONFIG_IWLMEI=y
CONFIG_WLAN_VENDOR_MEDIATEK=y
CONFIG_MT76=y                         # MediaTek MT76 (common)
CONFIG_MT76_CONNAC_LIB=y
